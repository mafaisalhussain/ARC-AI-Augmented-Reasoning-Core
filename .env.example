# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Embeddings
EMBED_MODEL=all-MiniLM-L6-v2

# Storage
CHROMA_DIR=./data/processed/chroma
RAW_DIR=./data/raw

# Retrieval
TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=75

# Scraper
USER_AGENT=ARC-AI-Research-Bot/0.1 (educational use)
REQUEST_DELAY=1.0
